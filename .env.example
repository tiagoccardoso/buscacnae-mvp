# App
NEXT_PUBLIC_APP_NAME=BuscaCNAE
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SPLINE_SCENE_URL=

# OpenAI CNAE assistant
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Neon PostgreSQL + autenticação própria
DATABASE_URL=
# Segredo usado para assinar o cookie de sessão. Use uma string longa e aleatória.
NEON_AUTH_COOKIE_SECRET=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_ANNUAL=
STRIPE_SUCCESS_URL=http://localhost:3000/dashboard?checkout=success
STRIPE_CANCEL_URL=http://localhost:3000/pricing?checkout=cancelled

# Discovery provider
# Provider principal do projeto
# Valor recomendado: hybrid
DISCOVERY_PROVIDER=hybrid

# CNPJ.ws
CNPJWS_API_TOKEN=
# Timeout do enriquecimento complementar por CNPJ em milissegundos.
CNPJWS_TIMEOUT_MS=5000

# Casa dos Dados
CASA_DOS_DADOS_API_KEY=

# Controle de acesso
# true = libera busca mesmo sem assinatura ativa (útil no desenvolvimento)
BYPASS_BILLING=false

# Cache
DISCOVERY_CACHE_TTL_HOURS=24
DISCOVERY_MAX_RESULTS=50

# Checkout avulso
MINIMUM_CHECKOUT_AMOUNT_CENTS=50

NEXT_PUBLIC_CONTACT_EMAIL=contato@buscacnae.com.br
